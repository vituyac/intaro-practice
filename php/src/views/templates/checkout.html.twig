{% extends "base.html.twig" %}

{% block title %}Оформление заказа - Интернет-магазин{% endblock %}

{% block content %}
<div class="row">
    <div class="col-12">
        <h1 class="mb-4">
            <i class="bi bi-credit-card me-2"></i>
            Оформление заказа
        </h1>
    </div>
</div>

{% if cart_items is defined and cart_items %}
<form id="checkoutForm" method="POST" action="/api/cart/making-an-order">
    <div class="row">
        <div class="col-lg-8">
            <!-- Customer Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-person me-2"></i>
                        Контактная информация
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="firstName" class="form-label">Имя *</label>
                            <input type="text" class="form-control" id="firstName" name="firstName" required
                                   value="{{ crmData.firstName|default(user.firstName|default('')) }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="lastName" class="form-label">Фамилия *</label>
                            <input type="text" class="form-control" id="lastName" name="lastName" required
                                   value="{{ crmData.lastName|default(user.lastName|default('')) }}">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="patronymic" class="form-label">Отчество</label>
                            <input type="text" class="form-control" id="patronymic" name="patronymic"
                                   value="{{ crmData.patronymic|default(user.patronymic|default('')) }}">
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label">Email *</label>
                            <input type="email" class="form-control" id="email" name="email" required 
                                   value="{{ crmData.email|default(user.email|default('')) }}">
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="phone" class="form-label">Телефон *</label>
                            <input type="tel" class="form-control" id="phone" name="phone" required 
                                   value="{{ crmData.phone|default(user.phone|default('')) }}" placeholder="+7 (999) 123-45-67">
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Delivery Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-truck me-2"></i>
                        Доставка
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="deliveryType" class="form-label">Способ доставки *</label>
                        <select class="form-select" id="deliveryType" name="deliveryType" required>
                            <option value="">Выберите способ доставки</option>
                            {% if delivery_types is defined %}
                                {% for delivery in delivery_types %}
                                    <option value="{{ delivery.code }}" data-cost="{{ delivery.cost|default(0) }}">
                                        {{ delivery.name }}
                                        {% if delivery.cost %}({{ delivery.cost }} ₽){% endif %}
                                    </option>
                                {% endfor %}
                            {% endif %}
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="deliveryAddress" class="form-label">Адрес доставки *</label>
                        <textarea class="form-control" id="deliveryAddress" name="deliveryAddress" rows="3" required 
                                  placeholder="Введите полный адрес доставки">{{ crmData.address.text|default(user.address|default('')) }}</textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label for="deliveryComment" class="form-label">Комментарий к доставке</label>
                        <textarea class="form-control" id="deliveryComment" name="deliveryComment" rows="2" 
                                  placeholder="Дополнительная информация для курьера"></textarea>
                    </div>
                </div>
            </div>
            
            <!-- Payment Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-credit-card me-2"></i>
                        Оплата
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="paymentType" class="form-label">Способ оплаты *</label>
                        <select class="form-select" id="paymentType" name="paymentType" required>
                            <option value="">Выберите способ оплаты</option>
                            {% if payment_types is defined %}
                                {% for payment in payment_types %}
                                    <option value="{{ payment.code }}">{{ payment.name }}</option>
                                {% endfor %}
                            {% endif %}
                        </select>
                    </div>
                </div>
            </div>
            
            <!-- Additional Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-chat-text me-2"></i>
                        Дополнительная информация
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="orderComment" class="form-label">Комментарий к заказу</label>
                        <textarea class="form-control" id="orderComment" name="orderComment" rows="3" 
                                  placeholder="Дополнительные пожелания или комментарии к заказу"></textarea>
                    </div>
                    
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="agreeTerms" name="agreeTerms" required>
                        <label class="form-check-label" for="agreeTerms">
                            Я согласен с <a href="/terms" target="_blank" class="text-decoration-none">условиями продажи</a> 
                            и <a href="/privacy" target="_blank" class="text-decoration-none">политикой конфиденциальности</a> *
                        </label>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <!-- Order Summary -->
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header">
                    <h5 class="mb-0">Ваш заказ</h5>
                </div>
                <div class="card-body">
                    <!-- Cart Items -->
                    <div class="mb-3">
                        {% for item in cart_items %}
                            <div class="d-flex align-items-center mb-2">
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 small">{{ item.product_name }}</h6>
                                    <small class="text-muted">{{ item.quantity }} × {{ item.price }} ₽</small>
                                </div>
                                <span class="fw-bold">{{ (item.price * item.quantity) }} ₽</span>
                            </div>
                        {% endfor %}
                    </div>
                    
                    <hr>
                    
                    <!-- Order Totals -->
                    <div class="d-flex justify-content-between mb-2">
                        <span>Товары:</span>
                        <span id="subtotal">{{ cart_total }} ₽</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span>Доставка:</span>
                        <span id="deliveryCost">Рассчитается</span>
                    </div>
                    
                    <hr>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <strong>Итого:</strong>
                        <strong id="totalCost">{{ cart_total }} ₽</strong>
                    </div>
                    
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-lg"></i>
                            Оформить заказ
                        </button>
                    </div>
                </div>
                
                <div class="card-footer text-center">
                    <small class="text-muted">
                        <i class="bi bi-shield-check me-1"></i>
                        Безопасная оплата
                    </small>
                </div>
            </div>
            
            <!-- Security Info -->
            <div class="card shadow-sm mt-3">
                <div class="card-body text-center">
                    <i class="bi bi-shield-lock display-4 text-success mb-2"></i>
                    <h6>Ваши данные защищены</h6>
                    <small class="text-muted">
                        Мы используем SSL-шифрование для защиты ваших персональных данных и платежной информации.
                    </small>
                </div>
            </div>
        </div>
    </div>
</form>

{% else %}
<!-- Empty Cart -->
<div class="row">
    <div class="col-12">
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-3">Корзина пуста</h3>
            <p class="text-muted">Добавьте товары в корзину, чтобы оформить заказ</p>
            <a href="/section" class="btn btn-primary">
                <i class="bi bi-shop"></i>
                Перейти к покупкам
            </a>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Phone number formatting
    const phoneInput = document.getElementById('phone');
    if (phoneInput) {
        phoneInput.addEventListener('input', function() {
            let value = this.value.replace(/\D/g, '');
            if (value.startsWith('8')) {
                value = '7' + value.slice(1);
            }
            if (value.startsWith('7') && value.length <= 11) {
                value = value.replace(/^7(\d{3})(\d{3})(\d{2})(\d{2})$/, '+7 ($1) $2-$3-$4');
                value = value.replace(/^7(\d{3})(\d{3})(\d{2})$/, '+7 ($1) $2-$3');
                value = value.replace(/^7(\d{3})(\d{3})$/, '+7 ($1) $2');
                value = value.replace(/^7(\d{3})$/, '+7 ($1');
                value = value.replace(/^7(\d{1,3})$/, '+7 ($1');
            }
            this.value = value;
        });
    }
    
    // Delivery cost calculation
    const deliverySelect = document.getElementById('deliveryType');
    const deliveryCostSpan = document.getElementById('deliveryCost');
    const totalCostSpan = document.getElementById('totalCost');
    const subtotalSpan = document.getElementById('subtotal');
    
    if (deliverySelect) {
        deliverySelect.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const deliveryCost = parseFloat(selectedOption.dataset.cost) || 0;
            const subtotal = parseFloat(subtotalSpan.textContent.replace(' ₽', '')) || 0;
            
            if (deliveryCost > 0) {
                deliveryCostSpan.textContent = deliveryCost + ' ₽';
                totalCostSpan.textContent = (subtotal + deliveryCost) + ' ₽';
            } else {
                deliveryCostSpan.textContent = 'Бесплатно';
                totalCostSpan.textContent = subtotal + ' ₽';
            }
        });
    }
    
    // Form submission
    const checkoutForm = document.getElementById('checkoutForm');
    if (checkoutForm) {
        checkoutForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const submitBtn = this.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Оформление заказа...';

            // Собираем данные формы вручную для JSON
            const data = {
                id: '{{ user.id|default("") }}',
                phone: document.getElementById('phone').value,
                address: document.getElementById('deliveryAddress').value,
                paymentType: document.getElementById('paymentType').value,
                deliveryType: document.getElementById('deliveryType').value
            };

            fetch('/api/cart/making-an-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.href = '/order-success?order_id=' + (data.order_id || '');
                } else {
                    throw new Error(data.message || 'Ошибка оформления заказа');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                let errorDiv = document.querySelector('.alert-danger');
                if (!errorDiv) {
                    errorDiv = document.createElement('div');
                    errorDiv.className = 'alert alert-danger';
                    checkoutForm.insertBefore(errorDiv, checkoutForm.firstChild);
                }
                errorDiv.innerHTML = '<i class="bi bi-exclamation-triangle"></i> ' + error.message;
                errorDiv.scrollIntoView({ behavior: 'smooth' });
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            });
        });
    }
    
    // Load delivery and payment types
    loadDeliveryTypes();
    loadPaymentTypes();
});

function loadDeliveryTypes() {
    fetch('/api/delivery-types')
        .then(response => response.json())
        .then(data => {
            if (data.success && data.deliveryTypes) {
                const select = document.getElementById('deliveryType');
                if (select) {
                    // Clear existing options except the first one
                    while (select.children.length > 1) {
                        select.removeChild(select.lastChild);
                    }
                    
                    // Add delivery types
                    data.deliveryTypes.forEach(delivery => {
                        const option = document.createElement('option');
                        option.value = delivery.code;
                        option.textContent = delivery.name;
                        if (delivery.cost) {
                            option.textContent += ` (${delivery.cost} ₽)`;
                            option.dataset.cost = delivery.cost;
                        }
                        select.appendChild(option);
                    });
                }
            }
        })
        .catch(error => {
            console.error('Error loading delivery types:', error);
        });
}

function loadPaymentTypes() {
    fetch('/api/payment-types')
        .then(response => response.json())
        .then(data => {
            if (data.success && data.paymentTypes) {
                const select = document.getElementById('paymentType');
                if (select) {
                    // Clear existing options except the first one
                    while (select.children.length > 1) {
                        select.removeChild(select.lastChild);
                    }
                    
                    // Add payment types
                    data.paymentTypes.forEach(payment => {
                        const option = document.createElement('option');
                        option.value = payment.code;
                        option.textContent = payment.name;
                        select.appendChild(option);
                    });
                }
            }
        })
        .catch(error => {
            console.error('Error loading payment types:', error);
        });
}
</script>
{% endblock %}

