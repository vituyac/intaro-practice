{% extends "base.html.twig" %}

{% block title %}{{ section.title }} - Интернет-магазин{% endblock %}

{% block content %}
{% if section is not defined or not section %}
    <script>
        window.location.href = '/section?id=1';
    </script>
{% endif %}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Главная</a></li>
        <li class="breadcrumb-item active" aria-current="page">{{ section.title }}</li>
    </ol>
</nav>

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1>{{ section.title }}</h1>
                {% if section.description %}
                    <p class="text-muted">{{ section.description }}</p>
                {% endif %}
            </div>
            <div class="text-muted">
                {% if pagination is defined and pagination.total_items is defined %}
                    Найдено товаров: {{ pagination.total_items }}
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% if children is defined and children %}
<div class="row mb-5">
    <div class="col-12">
        <h3 class="mb-3">Подкategории</h3>
    </div>
    {% for child_section in children %}
        <div class="col-md-6 col-lg-4 mb-3">
            <div class="card border-0 shadow-sm product-card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-folder text-primary me-2"></i>
                        {{ child_section.title }}
                    </h5>
                    {% if child_section.description %}
                        <p class="card-text text-muted">{{ child_section.description }}</p>
                    {% endif %}
                    <a href="/section?id={{ child_section.id }}" class="btn btn-outline-primary btn-sm">
                        Перейти
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
{% endif %}

{% if offers is defined and offers %}
<div class="row mb-4">
    <div class="col-12">
        <h3 class="mb-3">Товары</h3>
    </div>
</div>

<div class="row" id="productsContainer">
    {% for offer in offers %}
        <div class="col-md-6 col-lg-4 mb-4 product-item">
            <div class="card h-100 border-0 shadow-sm product-card">
                {% if offer.image %}
                    <img src="{{ offer.image }}" class="card-img-top" alt="{{ offer.name }}" style="height: 250px; object-fit: cover;">
                {% else %}
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                        <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                    </div>
                {% endif %}
                
                <div class="card-body d-flex flex-column">
                    <div class="text-muted" style="font-size: 0.95rem; margin-bottom: 0.5rem;">
                        <a href="/offer?id={{ offer.id }}" class="text-decoration-none text-secondary">{{ offer.title }}</a>
                    </div>
                    
                    {% if offer.description %}
                        <p class="card-text text-muted small">{{ offer.description|slice(0, 100) }}{% if offer.description|length > 100 %}...{% endif %}</p>
                    {% endif %}
                    
                    <div class="mt-auto">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="h5 text-primary mb-0">{{ offer.price }} ₽</span>
                            {% if offer.old_price %}
                                <span class="text-muted text-decoration-line-through">{{ offer.old_price }} ₽</span>
                            {% endif %}
                        </div>
                        
                        <div class="d-grid gap-2">
                            <a href="/offer?id={{ offer.id }}" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye"></i>
                                Подробнее
                            </a>
                            {% if user %}
                                <button class="btn btn-primary btn-sm add-to-cart" data-offer-id="{{ offer.id }}">
                                    <i class="bi bi-cart-plus"></i>
                                    В корзину
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

{% if pagination is defined and pagination.total_pages > 1 %}
<div class="row">
    <div class="col-12">
        <nav aria-label="Pagination">
            <ul class="pagination justify-content-center">
                {% if pagination.current_page > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="?id={{ section.id }}&page={{ pagination.current_page - 1 }}">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                {% endif %}
                
                {% for page in 1..pagination.total_pages %}
                    {% if page == pagination.current_page %}
                        <li class="page-item active">
                            <span class="page-link">{{ page }}</span>
                        </li>
                    {% elseif page >= pagination.current_page - 2 and page <= pagination.current_page + 2 %}
                        <li class="page-item">
                            <a class="page-link" href="?id={{ section.id }}&page={{ page }}">{{ page }}</a>
                        </li>
                    {% elseif page == 1 or page == pagination.total_pages %}
                        <li class="page-item">
                            <a class="page-link" href="?id={{ section.id }}&page={{ page }}">{{ page }}</a>
                        </li>
                    {% elseif page == pagination.current_page - 3 or page == pagination.current_page + 3 %}
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    {% endif %}
                {% endfor %}
                
                {% if pagination.current_page < pagination.total_pages %}
                    <li class="page-item">
                        <a class="page-link" href="?id={{ section.id }}&page={{ pagination.current_page + 1 }}">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    </div>
</div>
{% endif %}

{% elseif not (children is defined and children|length > 0) %}
<div class="row">
    <div class="col-12 text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <h3 class="mt-3">Товары не найдены</h3>
        <p class="text-muted">В данной категории пока нет товаров</p>
        <a href="/" class="btn btn-primary">
            <i class="bi bi-house"></i>
            На главную
        </a>
    </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const addToCartButtons = document.querySelectorAll('.add-to-cart');
    
    addToCartButtons.forEach(button => {
        button.addEventListener('click', function() {
            const offerId = this.dataset.offerId;
            const originalText = this.innerHTML;
            
            this.disabled = true;
            this.innerHTML = '<i class="bi bi-hourglass-split"></i> Добавление...';
            
            fetch('/api/cart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    offer_id: offerId,
                    quantity: 1
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.message) {
                    this.innerHTML = '<i class="bi bi-check"></i> Добавлено';
                    this.classList.remove('btn-primary');
                    this.classList.add('btn-success');
                    
                    const cartBadge = document.querySelector('.cart-badge');
                    if (cartBadge) {
                        const currentCount = parseInt(cartBadge.textContent) || 0;
                        cartBadge.textContent = currentCount + 1;
                    }
                    
                    setTimeout(() => {
                        this.innerHTML = originalText;
                        this.classList.remove('btn-success');
                        this.classList.add('btn-primary');
                        this.disabled = false;
                    }, 2000);
                } else {
                    throw new Error(data.error || data.message || 'Ошибка добавления в корзину');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                this.innerHTML = '<i class="bi bi-exclamation-triangle"></i> Ошибка';
                this.classList.remove('btn-primary');
                this.classList.add('btn-danger');
                
                setTimeout(() => {
                    this.innerHTML = originalText;
                    this.classList.remove('btn-danger');
                    this.classList.add('btn-primary');
                    this.disabled = false;
                }, 2000);
            });
        });
    });
});
</script>
{% endblock %}

