{% extends "base.html.twig" %}

{% block title %}История заказов - Интернет-магазин{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-3">
        <!-- Profile Sidebar -->
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="bi bi-person-circle display-4 text-primary"></i>
                </div>
                <h5>{{ user.firstName }} {{ user.lastName }}</h5>
                <p class="text-muted">{{ user.email }}</p>
            </div>
        </div>
        
        <div class="card shadow-sm mt-3">
            <div class="list-group list-group-flush">
                <a href="/profile" class="list-group-item list-group-item-action">
                    <i class="bi bi-person me-2"></i>
                    Личные данные
                </a>
                <a href="/orders" class="list-group-item list-group-item-action active">
                    <i class="bi bi-bag me-2"></i>
                    История заказов
                </a>
                <a href="/api/logout" class="list-group-item list-group-item-action text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    Выйти
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-9">
        <!-- Orders Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="bi bi-bag-check me-2"></i>
                История заказов
            </h2>
            
            <!-- Filters -->
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" id="statusFilter" style="width: auto;">
                    <option value="">Все статусы</option>
                    <option value="new">Новый</option>
                    <option value="processing">В обработке</option>
                    <option value="shipped">Отправлен</option>
                    <option value="delivered">Доставлен</option>
                    <option value="cancelled">Отменен</option>
                </select>
                
                <select class="form-select form-select-sm" id="periodFilter" style="width: auto;">
                    <option value="">Все время</option>
                    <option value="month">За месяц</option>
                    <option value="quarter">За квартал</option>
                    <option value="year">За год</option>
                </select>
            </div>
        </div>
        
        {% if orders is defined and orders %}
            <!-- Orders List -->
            {% for order in orders %}
                <div class="card shadow-sm mb-3 order-card" data-status="{{ order.status is iterable ? order.status.code : order.status }}" data-date="{{ order.createdAt }}">
                    <div class="card-header">
                        <div class="row align-items-center">
                            <div class="col-md-3">
                                <h6 class="mb-0">Заказ #{{ order.number }}</h6>
                                <small class="text-muted">{{ order.createdAt|date('d.m.Y H:i') }}</small>
                            </div>
                            <div class="col-md-3">
                                {% set status_class = {
                                    'new': 'bg-info',
                                    'processing': 'bg-warning',
                                    'shipped': 'bg-primary',
                                    'delivered': 'bg-success',
                                    'cancelled': 'bg-danger'
                                } %}
                                {% set status_text = {
                                    'new': 'Новый',
                                    'processing': 'В обработке',
                                    'shipped': 'Отправлен',
                                    'delivered': 'Доставлен',
                                    'cancelled': 'Отменен'
                                } %}
                                <span class="badge {{ status_class[order.status is iterable ? order.status.code : order.status]|default('bg-secondary') }}">
                                    {{ status_text[order.status is iterable ? order.status.code : order.status]|default(order.status is iterable ? order.status.name : order.status) }}
                                </span>
                            </div>
                            <div class="col-md-3">
                                <strong>{{ order.totalSumm }} ₽</strong>
                            </div>
                            <div class="col-md-3 text-end">
                                <button class="btn btn-outline-primary btn-sm toggle-order" data-bs-toggle="collapse" 
                                        data-bs-target="#order-{{ order.id }}" aria-expanded="false">
                                    <i class="bi bi-chevron-down"></i>
                                    Подробнее
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="collapse" id="order-{{ order.id }}">
                        <div class="card-body">
                            <!-- Order Details -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <h6>Информация о доставке</h6>
                                    <p class="mb-1">
                                        <strong>Способ доставки:</strong> 
                                        {% if order.delivery.code %}
                                            {% if order.delivery.code == 'courier' %}
                                                Курьерская доставка
                                            {% elseif order.delivery.code == 'pickup' %}
                                                Самовывоз
                                            {% elseif order.delivery.code == 'post' %}
                                                Почта России
                                            {% else %}
                                                {{ order.delivery.code }}
                                            {% endif %}
                                        {% else %}
                                            Не указан
                                        {% endif %}
                                    </p>
                                    <p class="mb-1"><strong>Адрес:</strong> {{ order.delivery.address.text|default(order.delivery.address|default('Не указан')) }}</p>
                                    {% if order.delivery.cost %}
                                        <p class="mb-0"><strong>Стоимость доставки:</strong> {{ order.delivery.cost }} ₽</p>
                                    {% endif %}
                                </div>
                                <div class="col-md-6">
                                    <h6>Информация об оплате</h6>
                                    <p class="mb-1">
                                        <strong>Способ оплаты:</strong> 
                                        {% if order.payments %}
                                            {% set payment = order.payments|first %}
                                            {% if payment.type == 'bank-card' %}
                                                Банковской картой
                                            {% elseif payment.type == 'cash' %}
                                                Наличными
                                            {% elseif payment.type == 'online' %}
                                                Онлайн оплата
                                            {% else %}
                                                {{ payment.type }}
                                            {% endif %}
                                        {% else %}
                                            Не указан
                                        {% endif %}
                                    </p>
                                    {% if order.payments %}
                                        {% set payment = order.payments|first %}
                                        <p class="mb-0">
                                            <strong>Статус оплаты:</strong> 
                                            <span class="badge {% if payment.status == 'paid' %}bg-success{% else %}bg-warning{% endif %}">
                                                {% if payment.status == 'paid' %}Оплачен{% else %}Ожидает оплаты{% endif %}
                                            </span>
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                            
                            <!-- Order Items -->
                            <h6>Товары в заказе</h6>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Товар</th>
                                            <th>Цена</th>
                                            <th>Количество</th>
                                            <th>Сумма</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for item in order.items %}
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        {% if item.offer.image %}
                                                            <img src="{{ item.offer.image is iterable ? item.offer.image.url : item.offer.image }}" class="me-2 rounded" 
                                                                 alt="{{ item.offer.name is iterable ? item.offer.name.name : item.offer.name }}" style="width: 40px; height: 40px; object-fit: cover;">
                                                        {% endif %}
                                                        <div>
                                                            <a href="/offer?id={{ item.offer.id }}" class="text-decoration-none">
                                                                {{ item.offer.name is iterable ? item.offer.name.name : item.offer.name }}
                                                            </a>
                                                            {% if item.offer.properties %}
                                                                <br><small class="text-muted">{{ item.offer.properties is iterable ? item.offer.properties.text : item.offer.properties }}</small>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>{{ item.initialPrice }} ₽</td>
                                                <td>{{ item.quantity }}</td>
                                                <td><strong>{{ (item.initialPrice * item.quantity) }} ₽</strong></td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <th colspan="3">Итого:</th>
                                            <th>{{ order.totalSumm }} ₽</th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                            
                            <!-- Order Actions -->
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div>
                                    {% if order.trackingNumber %}
                                        <span class="text-muted">Трек-номер: <strong>{{ order.trackingNumber }}</strong></span>
                                    {% endif %}
                                </div>
                                <div>
                                    {% if order.status == 'delivered' %}
                                        <button class="btn btn-outline-success btn-sm" onclick="leaveReview({{ order.id }})">
                                            <i class="bi bi-star"></i>
                                            Оставить отзыв
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
            
            <!-- Pagination -->
            {% if pagination is defined and pagination.total_pages > 1 %}
                <nav aria-label="Orders pagination" class="mt-4">
                    <ul class="pagination justify-content-center">
                        {% if pagination.current_page > 1 %}
                            <li class="page-item">
                                <a class="page-link" href="?page={{ pagination.current_page - 1 }}">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        {% endif %}
                        
                        {% for page in 1..pagination.total_pages %}
                            {% if page == pagination.current_page %}
                                <li class="page-item active">
                                    <span class="page-link">{{ page }}</span>
                                </li>
                            {% elseif page >= pagination.current_page - 2 and page <= pagination.current_page + 2 %}
                                <li class="page-item">
                                    <a class="page-link" href="?page={{ page }}">{{ page }}</a>
                                </li>
                            {% elseif page == 1 or page == pagination.total_pages %}
                                <li class="page-item">
                                    <a class="page-link" href="?page={{ page }}">{{ page }}</a>
                                </li>
                            {% elseif page == pagination.current_page - 3 or page == pagination.current_page + 3 %}
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            {% endif %}
                        {% endfor %}
                        
                        {% if pagination.current_page < pagination.total_pages %}
                            <li class="page-item">
                                <a class="page-link" href="?page={{ pagination.current_page + 1 }}">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </nav>
            {% endif %}
            
        {% else %}
            <!-- No Orders -->
            <div class="text-center py-5">
                <i class="bi bi-bag-x display-1 text-muted"></i>
                <h3 class="mt-3">У вас пока нет заказов</h3>
                <p class="text-muted">Начните покупки в нашем интернет-магазине</p>
                <a href="/section" class="btn btn-primary">
                    <i class="bi bi-shop"></i>
                    Перейти к покупкам
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Toggle order details
    const toggleButtons = document.querySelectorAll('.toggle-order');
    toggleButtons.forEach(button => {
        button.addEventListener('click', function() {
            const icon = this.querySelector('i');
            const isExpanded = this.getAttribute('aria-expanded') === 'true';
            
            if (isExpanded) {
                icon.classList.remove('bi-chevron-up');
                icon.classList.add('bi-chevron-down');
            } else {
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-up');
            }
        });
    });
    
    // Filters
    const statusFilter = document.getElementById('statusFilter');
    const periodFilter = document.getElementById('periodFilter');
    
    function applyFilters() {
        const selectedStatus = statusFilter.value;
        const selectedPeriod = periodFilter.value;
        const orderCards = document.querySelectorAll('.order-card');
        
        orderCards.forEach(card => {
            let showCard = true;
            
            // Status filter
            if (selectedStatus && card.dataset.status !== selectedStatus) {
                showCard = false;
            }
            
            // Period filter
            if (selectedPeriod && showCard) {
                const orderDate = new Date(card.dataset.date);
                const now = new Date();
                let cutoffDate = new Date();
                
                switch (selectedPeriod) {
                    case 'month':
                        cutoffDate.setMonth(now.getMonth() - 1);
                        break;
                    case 'quarter':
                        cutoffDate.setMonth(now.getMonth() - 3);
                        break;
                    case 'year':
                        cutoffDate.setFullYear(now.getFullYear() - 1);
                        break;
                }
                
                if (orderDate < cutoffDate) {
                    showCard = false;
                }
            }
            
            card.style.display = showCard ? 'block' : 'none';
        });
    }
    
    statusFilter.addEventListener('change', applyFilters);
    periodFilter.addEventListener('change', applyFilters);
});

function leaveReview(orderId) {
    // This would typically open a review modal or redirect to a review page
    alert('Функция оставления отзывов будет реализована в следующей версии');
}
</script>
{% endblock %}

